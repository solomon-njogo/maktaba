# Required: your Notion integration secret (https://www.notion.so/my-integrations)
NOTION_TOKEN=your_notion_integration_secret

# Required: the Notion database to enrich
NOTION_DATABASE_ID=your_notion_database_id

# Google Books API key for higher quota
GOOGLE_BOOKS_API_KEY=

# Watch mode (auto-fill when you type ISBN): run `npm run watch` or set MAKTABA_WATCH=1
# Optional: poll interval in ms (min 3000). Default 12000.
# MAKTABA_POLL_INTERVAL_MS=12000

# Notion webhooks (HTTPS API route only — not the static homepage):
# After verifying in Notion UI, paste the same token here to validate X-Notion-Signature.
# NOTION_WEBHOOK_VERIFICATION_TOKEN=secret_...

# Daily empty-field backfill (CLI): `npm run daily` — at most once per 24h unless you change interval.
# MAKTABA_DAILY_INTERVAL_MS=86400000
# MAKTABA_DAILY_STATE_FILE=.maktaba-daily-fill.json

# Force a one-off empty-field pass (no 24h gate): `npm run fill-empty`
# MAKTABA_FILL_EMPTY=1

# Vercel: optional HTTP trigger for the same pass — set CRON_SECRET, deploy, then add a Cron
# in the Vercel project (e.g. daily GET /api/daily-fill). Vercel sends Authorization: Bearer CRON_SECRET.
# CRON_SECRET=
